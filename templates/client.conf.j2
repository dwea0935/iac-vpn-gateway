[Interface]
Address = {{ peer_ip }}/32, fd42:42:42::{{ peer_ip | split('.') | last }}/128
PrivateKey = {{ peer_priv_key.stdout }}
DNS = {{ client_dns_ipv4 }}, {{ client_dns_ipv6 }}
MTU = 1360

[Peer]
PublicKey = {{ server_pub_key.stdout }}
Endpoint = {{ server_public_ip }}:51820
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = 25
